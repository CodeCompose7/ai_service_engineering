# Copy this file to .env at the repo root and fill in the values.
# .env is gitignored — never commit real keys.
#
# 원칙: 모든 생성(LLM) 호출은 LiteLLM을 경유한다. 아래 키는 LiteLLM이
# 프로바이더를 고를 때 읽어가는 표준 환경변수 이름이다.

# === 기본 프로바이더 ===
# 이 과정 코드가 먼저 시도할 프로바이더입니다. (LiteLLM 표준 변수는 아니고, 예제 코드가 읽습니다)
# 이 값이 가리키는 프로바이더를 먼저 찾아보고, 준비가 안 되어 있으면(키가 없거나 연결 실패)
# 사용 가능한 다른 프로바이더로 넘어갑니다.
# 가능한 값: ollama, gemini, openai, anthropic
DEFAULT_PROVIDER=ollama

# 아래 네 프로바이더 중 적어도 하나는 준비되어 있어야 합니다. 쓰는 것만 채우면 됩니다.

# === Gemini (클라우드, 무료 티어, 권장) ===
# Google Gemini API key — https://aistudio.google.com/api-keys
GEMINI_API_KEY=

# === OpenAI (클라우드, 유료) ===
# OpenAI API key — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# === Claude (클라우드, 유료) ===
# Anthropic Claude API key — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# === Ollama (로컬 무료 / 클라우드 무료 혹은 유료) ===
# host에 설치 후 모델을 받습니다. devcontainer 안에서는 host.docker.internal로 접근합니다.
# LiteLLM은 OLLAMA_API_BASE 환경변수로 base URL을 읽고, 모델은 "ollama/<모델>" 형태로 부릅니다.
OLLAMA_API_BASE=http://host.docker.internal:11434
# `ollama pull`로 받은 모델 이름. 다른 옵션 예: gemma4:12b-mxfp8(양자화), qwen2.5, llama3.x
# 이름 끝에 -cloud를 붙이면 Ollama Cloud의 큰 모델을 부릅니다. 예: gemma4:31b-cloud (무료 한도 또는 유료)
OLLAMA_MODEL=gemma4:12b
# Ollama Cloud(-cloud) 모델을 쓸 때만 필요합니다. 로컬 모델은 비워 둬도 됩니다.
# 호스트에서 `ollama signin`으로 로그인했다면 로컬 데몬이 대신 인증하므로 이 키 없이도 동작합니다.
# 키로 직접 쓰려면 https://ollama.com 설정의 API keys에서 발급해 넣습니다.
OLLAMA_API_KEY=

# === 임베딩 ===
# 임베딩은 LiteLLM 미경유 예외 — sentence-transformers로 HF 모델을 직접 실행합니다.
# 키가 필요 없으며, 모델은 최초 실행 시 자동 다운로드됩니다. (기본 BAAI/bge-m3)
# 다른 모델을 쓰려면 코드/환경에서 모델명을 바꾸세요. (한국어 경량 대안: jhgan/ko-sroberta-multitask)
EMBEDDING_MODEL=BAAI/bge-m3
